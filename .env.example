# App runtime
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=salary_negotiation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Auth and admin seed
JWT_SECRET=change_this_to_a_secure_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ADMIN_SEED_EMAIL=admin@salarysafe.dev
ADMIN_SEED_PASSWORD=admin123!

# LLM provider (openai|azure_openai)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=replace_with_openai_api_key_when_using_openai
OPENAI_MODEL=gpt-5.4

# Azure OpenAI
AZURE_OPENAI_API_KEY=replace_with_azure_key_when_using_azure_openai
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=your-azure-openai-deployment

# App defaults and logging
DEFAULT_PROMPT_SET_VERSION=1.0
DEFAULT_CURRENCY=USD
DEFAULT_JURISDICTION=US
LOG_LEVEL=INFO

# Mail
MAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=noreply@salarysafe.dev
MAIL_OVERRIDE_ADDRESS=
MAIL_OVERRIDE_ENABLED=false

# DigitalOcean VPS deployment scripts
DIGITAL_OCEAN-DROPLET_ID=your-droplet-name
DIGITAL_OCEAN_VPS_ROOT_PW=replace_with_vps_root_password
DIGITAL_OCEAN_API_TOKEN=replace_with_digitalocean_api_token
